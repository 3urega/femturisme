AGENT_SECRET_KEY=change-me-in-production

# LLM Provider: dummy | anthropic | openai | gemini
AGENT_LLM_PROVIDER=dummy

# Anthropic — default: claude-haiku-4-5-20251001 (lightweight, fast)
AGENT_ANTHROPIC_API_KEY=
AGENT_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI — default: gpt-4o-mini (lightweight, fast)
AGENT_OPENAI_API_KEY=
AGENT_OPENAI_MODEL=gpt-4.1-mini

# Google Gemini — default: gemini-2.0-flash (lightweight, fast)
AGENT_GEMINI_API_KEY=
AGENT_GEMINI_MODEL=gemini-2.0-flash

# Agent behaviour
AGENT_MAX_TOOL_ITERATIONS=5
