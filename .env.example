# =============================================================================
# agent_femturisme — plantilla .env (copiar a .env i omplir)
# Variables accepten prefix AGENT_ (ex. AGENT_MYSQL_HOST) o sense prefix.
# =============================================================================

# --- Agent ---
AGENT_SECRET_KEY=change-me-in-production

# LLM Provider: dummy | anthropic | openai | gemini
#
# Dev local: usa el provider real + API key del client (anthropic/openai/gemini).
# dummy: només per tests automàtics (pytest / TestingConfig), no cal per arrencar main.py
AGENT_LLM_PROVIDER=anthropic

# Anthropic — default: claude-haiku-4-5-20251001 (lightweight, fast)
AGENT_ANTHROPIC_API_KEY=
AGENT_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI — default: gpt-4.1-mini (lightweight, fast); també per embeddings RAG
AGENT_OPENAI_API_KEY=
AGENT_OPENAI_MODEL=gpt-4.1-mini

# Google Gemini — default: gemini-2.0-flash (lightweight, fast)
AGENT_GEMINI_API_KEY=
AGENT_GEMINI_MODEL=gemini-2.0-flash

# Agent behaviour
AGENT_MAX_TOOL_ITERATIONS=5

# --- MySQL femturisme CMS (read-only) ---
# Dev local: importar dump del client → 127.0.0.1 (veure docs/devs/desenvolupament-local.md §9)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=agent_read
MYSQL_PASSWORD=
MYSQL_DATABASE=femturisme
MYSQL_CONNECT_TIMEOUT=5

# --- PostgreSQL agent (RAG / documents) — Fase 5+ ---
# Instància gestionada externa amb pgvector; no cal en Fase 1 xat públic
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=agent_app
POSTGRES_PASSWORD=
POSTGRES_DATABASE=agent_femturisme
POSTGRES_CONNECT_TIMEOUT=5

# --- Embeddings / ops ---
EMBEDDING_MODEL=text-embedding-3-small
LOG_LEVEL=INFO
DOCUMENT_STORAGE_PATH=data/guides
