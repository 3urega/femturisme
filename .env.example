# =============================================================================
# agent_femturisme — plantilla .env (copiar a .env i omplir)
# Variables accepten prefix AGENT_ (ex. AGENT_MYSQL_HOST) o sense prefix.
# =============================================================================

# --- Agent ---
AGENT_SECRET_KEY=change-me-in-production

# LLM Provider: dummy | anthropic | openai | gemini
#
# Dev local: usa el provider real + API key del client (anthropic/openai/gemini).
# dummy: només per tests automàtics (pytest / TestingConfig), no cal per arrencar main.py
AGENT_LLM_PROVIDER=anthropic

# Anthropic — default: claude-haiku-4-5-20251001 (lightweight, fast)
AGENT_ANTHROPIC_API_KEY=
AGENT_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI — default: gpt-4.1-mini (lightweight, fast); també per embeddings RAG
AGENT_OPENAI_API_KEY=
AGENT_OPENAI_MODEL=gpt-4.1-mini

# Google Gemini — default: gemini-2.0-flash (lightweight, fast)
AGENT_GEMINI_API_KEY=
AGENT_GEMINI_MODEL=gemini-2.0-flash

# Agent behaviour
AGENT_MAX_TOOL_ITERATIONS=5

# =============================================================================
# MySQL femturisme CMS (read-only)
# =============================================================================
# Un sol conjunt actiu al .env: descomenta UN bloc (dev o prod).
# Usuari només lectura (SELECT). L'agent no escriu al CMS.
# Verificació: python scripts/test_sql_queries.py --ping
# Tests SQL:    python -m pytest -m integration -v
#
# Veure docs/devs/desenvolupament-local.md §7.3

# --- DEV — Railway (còpia dades producció; entorn actual de l'equip) ---
# Credencials al panell Railway → servei MySQL → Variables / Connect.
# El port sol ser diferent de 3306. SSL pot ser obligatori (veure nota al final).
MYSQL_HOST=
MYSQL_PORT=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_CONNECT_TIMEOUT=15

# --- PROD — MySQL del client (staging / producció; encara sense accés dev) ---
# Quan el client proporcioni usuari read-only i host, substitueix el bloc DEV:
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_USER=agent_read
# MYSQL_PASSWORD=
# MYSQL_DATABASE=femturisme
# MYSQL_CONNECT_TIMEOUT=5

# --- Alternativa local (dump importat al PC; §9 desenvolupament-local.md) ---
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=agent_read
# MYSQL_PASSWORD=
# MYSQL_DATABASE=femturisme
# MYSQL_CONNECT_TIMEOUT=5

# Opcional Railway / hosts gestionats: si la connexió falla sense SSL, caldrà
# afegir suport MYSQL_SSL al codi (issue futura o #11).

# --- PostgreSQL agent (RAG / documents) — Fase 5+ ---
# Instància gestionada externa amb pgvector (Supabase, Neon…); no cal en Fase 1 xat públic
# Supabase: habilita extensió "vector" al dashboard; sslmode=require (auto si host *.supabase.co)
# Si el port 5432 està bloquejat (Windows), usa pooler Session mode :6543 i usuari postgres.<project-ref>
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=agent_femturisme
POSTGRES_CONNECT_TIMEOUT=5
# POSTGRES_SSLMODE=require

# --- Embeddings / ops ---
EMBEDDING_MODEL=text-embedding-3-small
LOG_LEVEL=INFO
REQUEST_LOGGING_ENABLED=true
RATE_LIMIT_PER_IP=30
RATE_LIMIT_PER_SESSION=20
RATE_LIMIT_WINDOW_SECONDS=60
DOCUMENT_STORAGE_PATH=data/guides

# --- Admin API (Fase 5+) ---
# Si està buit, les rutes /admin/api/* queden obertes en dev local.
# Producció: definir un secret fort i enviar Authorization: Bearer <token>
# ALLOWED_ADMIN_IPS (tecnic §10.3) encara no implementat — deute ops.
ADMIN_API_TOKEN=
